# Copy this file to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env

# --- MySQL (used now: db.py + all DB code) ---
MYSQL_HOST=localhost
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=idx_exchange

# --- Gemini (LLM completions from Week 8 RAG; via OpenAI-compatible endpoint) ---
# Free key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=AQ...
# Embeddings run locally via sentence-transformers (all-MiniLM-L6-v2) — no key needed.

# --- Email (needed from Week 11: draft-then-approve email workflow) ---
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
